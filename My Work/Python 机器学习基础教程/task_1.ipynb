   "source": [
    "from sklearn.cluster import KMeans\n",
    "import numpy as np\n",
    "\n",
    "data = np.array([[0, 0], [1, 0], [1, 1],[4,4],[5,4],[5,5]])\n",
    "\n",
    "kmeans = KMeans(n_clusters=2,random_state=42)\n",
    "kmeans.fit(data)\n",
    "centers = kmeans.cluster_centers_\n",
    "print(centers)"
   ]
